/**
 * Quick verification script for AIService mock mode
 * Run with: npx tsx test-mock-mode.ts
 */
import 'reflect-metadata';
import { AIService } from './src/services/ai.service';

console.log('=== Testing AIService Mock Mode ===\n');

// Test 1: Initialize AIService without API key
console.log('Test 1: Initializing AIService (should be in mock mode)...');
const aiService = new AIService();
console.log('✓ AIService initialized successfully\n');

// Test 2: Test FullStack scenario
console.log('Test 2: Testing FullStack scenario detection...');
const fullStackResume = 'I am a developer with 5 years of experience in React and Node.js';
const jobDesc = 'Looking for a FullStack developer';

console.log('Calling screenCandidate with FullStack resume...');
const startTime = Date.now();

aiService.screenCandidate(fullStackResume, jobDesc)
    .then(result => {
        const elapsed = Date.now() - startTime;
        console.log(`✓ Screening completed in ${elapsed}ms`);
        console.log('Result:', JSON.stringify(result, null, 2));
        
        // Verify result structure
        console.log('\nVerifying result structure:');
        console.log(`  - score: ${result.score} (expected: 95-100)`);
        console.log(`  - recommendation: ${result.recommendation} (expected: PROCEED)`);
        console.log(`  - keyMatches: ${result.keyMatches.length} items`);
        console.log(`  - missingSkills: ${result.missingSkills.length} items`);
        
        if (result.score >= 95 && result.score <= 100) {
            console.log('\n✓ All checks passed! Mock mode is working correctly.');
        } else {
            console.log('\n✗ Score out of expected range!');
        }
    })
    .catch(error => {
        console.error('✗ Error during screening:', error);
        process.exit(1);
    });
